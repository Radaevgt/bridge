{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/vite/bin/vite.js", "--port", "5173", "--host", "127.0.0.1"],
      "port": 5173,
      "cwd": "bridge-frontend"
    },
    {
      "name": "backend",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "app.main:application", "--port", "8000"],
      "port": 8000,
      "cwd": "bridge-backend"
    }
  ]
}
